#!/bin/bash
# Pre-commit check: ensure BUILD_TIME placeholders exist

# Check if any HTML files are being committed
if git diff --cached --name-only | grep -q '\.html$'; then
  # Verify placeholders exist in staged files
  for file in docs/index.html docs/boki1/index.html docs/devops/index.html; do
    if git show ":$file" 2>/dev/null | grep -q "__BUILD_TIME__"; then
      continue
    else
      echo "❌ ERROR: Missing __BUILD_TIME__ placeholder in $file"
      echo ""
      echo "Fix: Run 'npm run build' before committing"
      exit 1
    fi
  done
fi

exit 0
