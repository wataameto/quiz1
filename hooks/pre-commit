#!/bin/bash
# Update build-info.json before commit
# This ensures build-info.json is always included in the commit

node scripts/update-build-time.js

# Add updated build-info.json, generated quiz-meta.json, and the version-bumped quiz index.html files to the commit
git add docs/build-info.json docs/quiz-meta.json docs/*/index.html

exit 0
